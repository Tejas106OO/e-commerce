# ─────────────────────────────────────────────────────
# LUXE Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to git!
# ─────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# PostgreSQL (Supabase / Neon / self-hosted)
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres?sslmode=require

# Redis (Upstash / Railway Redis / self-hosted)
REDIS_URL=redis://default:yourpassword@your-redis-host:6379

# JWT
JWT_SECRET=replace_with_a_secure_random_64_char_string
JWT_EXPIRES=7d

# Razorpay (Test keys from razorpay.com/dashboard → API Keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Cloudinary (cloudinary.com → Dashboard → Account Details)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=your_api_secret

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Logging
LOG_QUERIES=false
