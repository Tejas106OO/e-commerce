# ─────────────────────────────────────────────────────
# LUXE Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# Variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────

# Backend API URL (your deployed Express server)
VITE_API_URL=http://localhost:5000

# Razorpay Test Key ID (from razorpay.com → Settings → API Keys)
# Use test keys for development, switch to live keys for production
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX

# Sentry DSN for error monitoring (sentry.io → Project → SDK Setup)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Google Analytics 4 Measurement ID (analytics.google.com → Admin → Data Streams)
VITE_GA_ID=G-XXXXXXXXXX
